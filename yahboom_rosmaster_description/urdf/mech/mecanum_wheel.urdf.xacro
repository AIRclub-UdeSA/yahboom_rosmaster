<?xml version="1.0"?>
<!--
  Mecanum wheel with sphere collision + fdir1 anisotropic friction.

  Each wheel is a sphere (single contact point) with:
    mu=1.0  along fdir1 (roller grip direction — high friction)
    mu2=0.0 perpendicular to fdir1 (roller free-rolling direction — zero friction)

  fdir1 is expressed in the robot base_footprint frame via ignition:expressed_in
  to match the native Gazebo mecanum demo's chassis-frame friction directions.
  Locomotion is commanded by the Gazebo MecanumDrive system; this collision and
  friction model remains the wheel-ground contact model that DART resolves.

  fdir1 values per wheel (set by caller in rosmaster_x3.urdf.xacro):
    FL, BR: "1 -1 0"
    FR, BL: "1  1 0"
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro"
       xmlns:ignition="http://ignitionrobotics.org/schema">

  <xacro:property name="wheel_radius"    value="0.0325"  />
  <xacro:property name="wheel_separation" value="0.169"  />
  <xacro:property name="wheel_width"     value="0.03040" />
  <xacro:property name="wheel_mass"      value="0.05"    />
  <xacro:property name="wheel_xoff"      value="0.08"    />
  <xacro:property name="wheel_yoff"      value="-0.01"   />

  <xacro:macro name="mecanum_wheel" params="prefix side x_reflect y_reflect fdir1:='1 0 0'">
    <link name="${prefix}${side}_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <mesh filename="file://$(find yahboom_rosmaster_description)/meshes/rosmaster_x3/visual/${side}_wheel_X3.STL"/>
        </geometry>
        <material name="dark_gray">
          <color rgba="0.2 0.2 0.2 1.0"/>
        </material>
      </visual>

      <!-- Sphere gives a single contact point. Required for ignition:expressed_in
           to correctly lock fdir1 to the chassis frame (cylinder gives an extended
           contact line which behaves unpredictably with directional friction). -->
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <sphere radius="${wheel_radius}"/>
        </geometry>
      </collision>

      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="${wheel_mass}"/>
        <xacro:property name="I_sphere" value="${(2.0/5.0) * wheel_mass * wheel_radius * wheel_radius}"/>
        <inertia ixx="${I_sphere}" ixy="0" ixz="0"
                 iyy="${I_sphere}" iyz="0"
                 izz="${I_sphere}"/>
      </inertial>
    </link>

    <joint name="${prefix}${side}_wheel_joint" type="continuous">
      <axis xyz="0 1 0"/>
      <parent link="${prefix}base_link"/>
      <child  link="${prefix}${side}_wheel_link"/>
      <origin xyz="${x_reflect*wheel_xoff} ${y_reflect*(wheel_separation/2+wheel_yoff)} ${-wheel_radius}"
              rpy="0 0 0"/>
      <dynamics damping="0.1" friction="0.0"/>
    </joint>

    <gazebo reference="${prefix}${side}_wheel_link">
      <collision>
        <surface>
          <friction>
            <ode>
              <!-- High friction along fdir1 (roller grip axis) -->
              <mu>1.0</mu>
              <!-- Zero friction perpendicular (roller free-rolling direction) -->
              <mu2>0.0</mu2>
              <!-- ignition:expressed_in locks fdir1 to the chassis frame.
                   base_footprint is the model root frame, equivalent to "chassis"
                   in the official Gazebo mecanum demo. -->
              <fdir1 ignition:expressed_in="${prefix}base_footprint">${fdir1}</fdir1>
              <slip1>0.0</slip1>
              <slip2>0.0</slip2>
            </ode>
          </friction>
          <contact>
            <ode>
              <kp>200000.0</kp>
              <kd>2000.0</kd>
              <min_depth>0.001</min_depth>
            </ode>
          </contact>
        </surface>
      </collision>
      <visual>
        <material>
          <ambient>0.2 0.2 0.2 1.0</ambient>
          <diffuse>0.2 0.2 0.2 1.0</diffuse>
          <specular>0.2 0.2 0.2 1.0</specular>
          <emissive>0.0 0.0 0.0 0.0</emissive>
        </material>
      </visual>
    </gazebo>
  </xacro:macro>

</robot>
